# Digital Resilience Assessment — Server Configuration
# Copy this file to .env and fill in your values

# Server port
PORT=3000

# Anthropic API — used to proxy Claude calls server-side
# If using a local proxy (e.g. via Copilot/LiteLLM), set ANTHROPIC_BASE_URL too
ANTHROPIC_API_KEY=your-api-key-here
ANTHROPIC_BASE_URL=https://api.anthropic.com

# Optional: shared secret header guard (X-API-Key).
# Leave blank for open access (rely on user auth instead).
DRA_API_KEY=

# CORS origin. Set to your domain in production, or * for open.
ALLOWED_ORIGIN=*
